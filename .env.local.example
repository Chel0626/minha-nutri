# Supabase Configuration
# Obtenha esses valores do seu projeto Supabase em https://supabase.com

# URL do seu projeto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anônima do Supabase (público, seguro para compartilhar)
NEXT_PUBLIC_SUPABASE_ANON_KEY=seu-chave-anonima-aqui

# Nota: Variáveis com prefixo NEXT_PUBLIC_ são expostas ao navegador
# Nunca coloque chaves secretas/privadas com este prefixo!
